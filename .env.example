# =================================
# Application
# =================================
NODE_ENV=development
PORT=3000
AUTH_SERVICE_PORT=3001

# =================================
# Database (PostgreSQL - Multi-Database)
# =================================
# Primary database URL (backward compatible)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sada_db?schema=public"

# Multi-database configuration
DATABASE_AUTH_URL="postgresql://postgres:postgres@localhost:5432/sada_auth?schema=public"
DATABASE_MAIN_URL="postgresql://postgres:postgres@localhost:5432/sada_main?schema=public"
DATABASE_REPORTING_URL="postgresql://postgres:postgres@localhost:5432/sada_reporting?schema=public"

# =================================
# Redis
# =================================
REDIS_URL="redis://localhost:6379"

# =================================
# JWT Configuration
# =================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# =================================
# SSO Session Cookie (auth-service)
# =================================
# Used to sign the sada_sid HttpOnly cookie that powers cross-app SSO.
# Falls back to JWT_SECRET if unset.
SESSION_COOKIE_SECRET=change-me-to-a-long-random-string
# Lifetime of the SSO session in Redis (matches refresh-token style: 15m / 1h / 7d)
SESSION_TTL=7d
# Set this to a parent domain (e.g. .example.com) to share the SSO cookie
# across subdomains. Leave empty for single-host setups.
SESSION_COOKIE_DOMAIN=

# =================================
# OAuth2 Configuration
# =================================
OAUTH_AUTHORIZATION_CODE_EXPIRES_IN=600
OAUTH_ACCESS_TOKEN_EXPIRES_IN=3600
OAUTH_REFRESH_TOKEN_EXPIRES_IN=2592000

# =================================
# LDAP Configuration (Internal Users)
# =================================
LDAP_URL=ldap://ldap.example.com:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin_password
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})

# =================================
# MySQL Configuration (Internal User Profiles)
# =================================
# Used for tb_master_pegawai employee data
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=main_db

# Email domain for internal users (auto-route to LDAP auth)
INTERNAL_EMAIL_DOMAIN=bpjstk.go.id

# =================================
# SPLP Configuration (Government SSO)
# =================================
SPLP_CLIENT_ID=your_splp_client_id
SPLP_CLIENT_SECRET=your_splp_client_secret
SPLP_AUTHORIZATION_URL=https://splp.go.id/oauth/authorize
SPLP_TOKEN_URL=https://splp.go.id/oauth/token
SPLP_USERINFO_URL=https://splp.go.id/api/userinfo
SPLP_REDIRECT_URI=http://localhost:3001/auth/splp/callback

# =================================
# Google OAuth Configuration
# =================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# =================================
# Facebook OAuth Configuration
# =================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/auth/facebook/callback

# =================================
# OIDC Configuration
# =================================
OIDC_ISSUER=http://localhost:3001

# =================================
# Single Domain (docker-compose.single-domain.yml)
# =================================
# URL publik domain Anda — dipakai sebagai OIDC issuer & callback OAuth
# Contoh: https://sso.panrb.go.id
DOMAIN_URL=http://localhost

# RSA Key Pair for RS256 token signing (leave empty to auto-generate in dev)
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem
RSA_KEY_ID=key-1

# =================================
# API Gateway Configuration
# =================================
AUTH_SERVICE_URL=http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# Stricter rate limit for auth endpoints (login/register)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# =================================
# Gravitee.io Configuration
# =================================
GRAVITEE_MANAGEMENT_API_URL=http://localhost:8083
GRAVITEE_GATEWAY_URL=http://localhost:8082
GRAVITEE_ADMIN_USERNAME=admin
GRAVITEE_ADMIN_PASSWORD=admin

# =================================
# Logging
# =================================
LOG_LEVEL=debug
LOG_FORMAT=dev

# =================================
# CORS Configuration
# =================================
CORS_ORIGIN=http://localhost:3002,http://localhost:3000

# =================================
# Audit Logging
# =================================
AUDIT_LOG_ENABLED=true

# Token cleanup interval in ms (default: 1 hour)
TOKEN_CLEANUP_INTERVAL_MS=3600000

# =================================
# Testing
# =================================
TEST_API_URL=http://localhost:3001
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sada_auth_test

# =================================
# Production (docker-compose.prod.yml)
# =================================
# See .env.prod.example for production configuration
# VERSION=1.0.0
# POSTGRES_USER=sada_user
# POSTGRES_PASSWORD=your-secure-password
# REDIS_PASSWORD=your-redis-password
# GATEWAY_PORT=3000
# AUTH_UI_PORT=3002
