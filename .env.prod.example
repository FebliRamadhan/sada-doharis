# ===========================================
# SADA API - Production Environment Template
# ===========================================
# Copy this file to .env.prod and fill in the values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ===========================================

# Versioning
VERSION=1.0.0

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=sada_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=sada_db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_PASSWORD=your-redis-password-here

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ===========================================
# SSO Session Cookie (auth-service)
# ===========================================
# Signs the sada_sid HttpOnly cookie that powers cross-app SSO.
# MUST be set in production — falls back to JWT_SECRET if unset.
SESSION_COOKIE_SECRET=change-me-min-32-chars-different-from-jwt-secret
# Lifetime of an SSO session in Redis (15m / 1h / 7d)
SESSION_TTL=7d
# Set to a parent domain (e.g. .example.com) so the cookie is shared by every
# subdomain that talks to auth-service. Leave empty when auth-service and the
# auth-ui live on a single host.
SESSION_COOKIE_DOMAIN=

# ===========================================
# Application Ports
# ===========================================
GATEWAY_PORT=3000
AUTH_UI_PORT=3002

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGIN=https://your-frontend-domain.com

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info

# ===========================================
# LDAP Configuration (Optional)
# ===========================================
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=
LDAP_SEARCH_FILTER=

# ===========================================
# SPLP (Government SSO) Configuration
# ===========================================
SPLP_CLIENT_ID=
SPLP_CLIENT_SECRET=
SPLP_AUTHORIZATION_URL=
SPLP_TOKEN_URL=
SPLP_USERINFO_URL=
SPLP_REDIRECT_URI=

# ===========================================
# Google OAuth Configuration (Optional)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ===========================================
# Facebook OAuth Configuration (Optional)
# ===========================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=
