{
    "name": "@sada/gateway",
    "version": "1.0.0",
    "description": "API Gateway Service",
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts",
